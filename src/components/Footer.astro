<style>
  .site-footer {
    margin: 3rem auto;
    font-size: var(--font-size__base--sm);
    color: #b6bdc6;
  }

  .site-footer .container {
    display: flex;
    align-items: center;
  }

  .site-footer a {
    display: block;
    height: 24px;
  }

  .site-footer svg {
    width: 24px;
    height: 24px;
    margin-right: 20px;
  }

  .site-footer svg path {
    fill: #b6bdc6;
  }
</style>
