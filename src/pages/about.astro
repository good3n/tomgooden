---
import Layout from '../layouts/Layout.astro'

const yearsExperience = new Date().getFullYear() - 2007
---

<Layout title="About Tom Gooden">
  <div class="about container">
    <header>
      <div>
        <img alt="Who even are you" src="/images/parks-and-rec-craig-who-even-are-you.gif" />
      </div>
      <div>
        <h1>Hey, I'm Tom.</h1>
        <p>
          Michigan-based developer and designer with {yearsExperience}+ years
          building custom web applications, internal tools, and everything
          in between.
        </p>
      </div>
    </header>
    <div class="about-main">
      <p>
        I'm a UX junkie who gets unreasonably excited about making complex
        things feel simple. I specialize in custom internal tooling,
        customer-facing applications, and full-stack web development. When
        I'm not working, I'm usually hanging out in the{' '}
        <a href="https://discord.gg/KntFa9p" rel="noopener noreferrer" target="_blank">
          CodeHelp discord server
        </a>.
      </p>
      <div class="blocks">
        <div class="block-pink">
          <span>{`<code/help>`}</span>
          <a class="button" href="https://discord.gg/KntFa9p" rel="noopener noreferrer" target="_blank">
            Join
          </a>
        </div>
        <div class="block-purple">
          <p>
            Here is a list of goodies I've compiled that I use in design,
            development, and just everyday life.
          </p>
          <a class="button button--purple" href="/uses/">Uses</a>
        </div>
      </div>

      <h2>Off the clock</h2>
      <p>
        Dad to 3 kids and{' '}
        <span class="strike">2</span> <span class="strike">3</span> 5
        dogs. Comic collector, Commander player, occasional fisherman, and
        serial side-project starter. I learn new things by building them,
        which is how most of my weekends disappear.
      </p>
    </div>
  </div>
</Layout>

<style>
  .about {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  @media (max-width: 899px) {
    .about {
      padding-top: 3rem;
    }
  }

  header {
    display: grid;
    grid-template-columns: 425px 1fr;
    gap: 100px;
    align-items: center;
    margin-bottom: 3rem;
  }

  @media (max-width: 899px) {
    header {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 0;
    }
  }

  header img {
    border-radius: 40px 0 40px 0;
  }

  .about h1 {
    margin-top: 0;
  }

  @media (max-width: 899px) {
    .about h1 {
      font-size: var(--font-size__h3);
    }
  }

  .about h2 {
    font-size: var(--font-size__h4);
  }

  .blocks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin: 4rem 0;
  }

  @media (max-width: 899px) {
    .blocks {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .blocks > div {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    font-size: var(--font-size__base--sm);
    gap: 30px;
  }

  @media (max-width: 899px) {
    .blocks > div {
      flex-direction: column;
      gap: 1rem;
    }

    .blocks > div :global(.button) {
      width: 100%;
      box-sizing: border-box;
      text-align: center;
    }
  }

  .block-pink {
    background: rgba(245, 45, 134, 0.1);
    color: rgb(245, 45, 134);
  }

  .block-pink span {
    font-family: var(--font-family__code);
    font-size: var(--font-size__h4);
  }

  .block-purple {
    background: rgba(113, 28, 180, 0.1);
    color: rgb(113, 28, 180);
  }

  .button--purple {
    background: rgb(113, 28, 180) !important;
    font-family: var(--font-family__code);
    color: #fff !important;
  }

  .blocks p {
    margin: 0;
  }
</style>
