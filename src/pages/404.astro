---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
import lostManImg from '../assets/images/404.png'
import balloonImg from '../assets/images/balloon.png'
---

<Layout title="404 Error - Page Not Found" bodyClass="not-found">
  <div class="not-found-page">
    <div class="container">
      <Image alt="404 not found" src={lostManImg} width={400} class="lost-man" />
      <h1>
        <span>4</span>
        <span>0</span>
        <span>4</span>
      </h1>
      <p>
        <span>This page was either moved or never existed. </span>
      </p>
      <p>
        <span>
          <a href="/">Back Home</a>
        </span>
      </p>
      <Image alt="404 not found" src={balloonImg} width={400} class="balloon" />
    </div>
  </div>
</Layout>

<style>
  .not-found-page {
    min-height: calc(100vh - 300px);
    overflow: hidden;
  }

  @media (max-width: 899px) {
    .not-found-page {
      min-height: calc(100vh - 272px);
    }
  }

  .container {
    position: relative;
    height: 100%;
    padding-top: 15.407rem;
  }

  h1 {
    font-size: 7.43rem;
    font-weight: 700;
    line-height: 1;
    margin: 0;
    position: absolute;
    top: 50px;
    right: 0;
    left: -50px;
    text-align: center;
    z-index: 2;
  }

  h1 span {
    position: relative;
    display: inline-block;
  }

  h1 span:nth-of-type(1) {
    top: 30px;
    transform: rotate(-20deg);
  }

  h1 span:nth-of-type(2) {
    left: 20px;
  }

  h1 span:nth-of-type(3) {
    left: 50px;
    transform: rotate(20deg);
  }

  p {
    font-weight: 300;
    font-size: var(--font-size__h4);
    line-height: 1.6;
    color: #777;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    text-align: center;
  }

  p:nth-of-type(2) {
    padding-left: 150px;
    transform: rotate(2deg);
    margin-top: -8px;
  }

  @media (max-width: 540px) {
    p:nth-of-type(2) {
      padding-left: 0;
      margin-top: 0;
      transform: rotate(4deg);
    }
  }

  p:nth-of-type(2) span {
    background: var(--color_red);
    padding: 0.402rem 30px;
  }

  p span {
    background: var(--color__headline);
    color: #fff;
    padding: 0.579rem 20px;
    display: inline-block;
  }

  p a {
    color: #fff;
    display: inline-block;
  }

  .lost-man {
    position: absolute;
    top: 25vh;
    left: 0;
    z-index: 1;
    height: auto;
  }

  .balloon {
    position: absolute;
    top: 0;
    right: 0;
    height: auto;
  }

  @media (max-width: 600px) {
    .balloon {
      right: -200px;
      top: -50px;
    }
  }
</style>
