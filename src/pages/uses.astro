---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
import usesImg from '../assets/images/uses.jpeg'
import items from '../data/uses.json'

const uniques = [...new Set(items.data.map((item: any) => item))]
---

<Layout title="Uses">
  <div class="uses">
    <header class="container">
      <div>
        <h1>/uses</h1>
        <p>
          A list of goodies that I use in my work and personal life. Full
          transparency, some of these links are referrals. Checkout more
          uses at{' '}
          <strong>
            <a href="https://uses.tech/?from=tomgooden.net" rel="nofollow noreferrer" target="_blank">
              uses.tech
            </a>
          </strong>.
        </p>
      </div>
      <Image
        alt="Tom Gooden Uses"
        src={usesImg}
        height={470}
        class="uses-hero"
        style="object-fit: cover; object-position: center -50px;"
      />
    </header>
    <div class="container container--skinny">
      <div class="grid">
        {uniques.map(({ categories, column }: any) => (
          <div>
            {categories.map(({ name, items: catItems }: any) => (
              <div>
                <h2>{name}</h2>
                <ul>
                  {catItems.map(({ title, link }: any) => {
                    const fromLink = link
                      ? link + (link.match(/\?./) ? '&' : '?') + 'from=tomgooden.net'
                      : null
                    return (
                      <li>
                        {fromLink ? (
                          <a href={fromLink} rel="nofollow noreferrer" target="_blank">
                            {title}
                          </a>
                        ) : (
                          title
                        )}
                      </li>
                    )
                  })}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .uses {
    margin-bottom: 5.5rem;
  }

  header {
    display: grid;
    grid-template-columns: 1fr 600px;
    align-items: center;
    gap: 100px;
  }

  @media (max-width: 899px) {
    header {
      display: block;
    }
  }

  header + .container {
    margin-top: 2rem;
  }

  .uses h1 {
    margin-bottom: 1rem;
  }

  @media (max-width: 899px) {
    .uses h1 {
      font-size: var(--font-size__h2);
    }
  }

  .uses h1 + p {
    margin: 0;
  }

  @media (max-width: 899px) {
    .uses h1 + p {
      margin-bottom: 2rem;
    }
  }

  .uses h2 {
    font-size: var(--font-size__h5);
    margin-bottom: 2rem;
  }

  .uses-hero {
    border-radius: 40px 0 40px 0;
    height: auto;
  }

  @media (max-width: 899px) {
    .uses-hero {
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .uses-hero {
      height: 300px !important;
    }
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 50px;
  }

  @media (max-width: 440px) {
    .grid {
      display: block;
    }
  }

  .grid > div:first-of-type {
    grid-column: 1 / 3;
  }

  .grid > div:first-of-type ul {
    columns: 2;
    column-gap: 50px;
  }

  @media (max-width: 440px) {
    .grid > div:first-of-type ul {
      columns: 1;
    }
  }

  .grid > div:first-of-type li {
    font-weight: 700;
    display: block;
    break-inside: avoid;
  }

  ul {
    margin: 0;
    padding-left: 0;
  }

  li {
    font-weight: 600;
    display: block;
    margin-bottom: 0.4rem;
  }

  li a {
    position: relative;
  }

  li a::after {
    content: '';
    height: 0;
    width: 100%;
    position: absolute;
    bottom: 0;
    right: 0;
    left: 0;
    background-color: var(--color_blue);
    opacity: 0.3;
    transition: height 0.2s ease;
    z-index: -1;
  }

  li a:hover::after {
    height: 7px;
  }
</style>
